# Copy to .env on the deploy host. Never commit the real .env.

# Paste from the Cloudflare Zero Trust dashboard after creating a tunnel.
# Dashboard: One.dash.cloudflare.com > Networks > Tunnels > Create a tunnel.
# Choose "Cloudflared" connector type; the token is shown on the install step.
CLOUDFLARE_TUNNEL_TOKEN=

# Public base URL the server uses when building per-submission links in
# the POST /api/v1/submit two-line response. Must match the hostname you
# bind in the Cloudflare tunnel's Public Hostname config.
BAREBOOT_PUBLIC_BASE=https://barelybooting.com
